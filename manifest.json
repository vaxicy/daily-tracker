{
    "manifest_version": 3,
    "name": "吃喝拉撒",
    "description": "全方位记录生活起居：吃、喝、拉、撒，养成健康好习惯。",
    "version": "3.0",
    "action": {
      "default_popup": "popup.html",
      "default_title": "健康追踪器",
      "default_icon": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "permissions": ["notifications", "storage", "alarms"],
    "icons": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
